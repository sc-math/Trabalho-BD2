# String de Conexão do Backend (usando a Role loja_app)
DATABASE_URL=postgresql://${LOJA_APP_USER}:${LOJA_APP_PASSWORD}@db:5432/${POSTGRES_DB}

# Credenciais de acesso do pgAdmin 4
PGADMIN_EMAIL=admin@lojavirtual.com
